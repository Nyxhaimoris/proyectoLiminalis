    },
    "techPage": {
        "title": "Our Tech Stack",
        "subtitle": "The architecture behind the Liminalis experience.",
        "sections": {
            "backend": {
                "title": "Backend & API",
                "description": "A solid and scalable foundation to manage your data with maximum efficiency.",
                "items": [
                    "**PHP 8.2 & CodeIgniter 4:** The engine powering our server logic, chosen for its incredible speed and small footprint.",
                    "**JWT Security:** Robust authentication via JSON Web Tokens to keep your session protected without sacrificing performance.",
                    "**PHPUnit Testing:** Automated test suite ensuring stability with every update."
                ]
            },
            "frontend": {
                "title": "Frontend & UX",
                "description": "Reactive interfaces designed for fluid and visually stunning navigation.",
                "items": [
                    "**React 18:** Component-based architecture for a fast and modular user experience.",
                    "**Framer Motion:** Smooth animations and state transitions that bring the UI to life.",
                    "**OGL:** High-performance WebGL integration for advanced, fluid visual effects.",
                    "**i18next:** Native multi-language support with automatic detection."
                ]
            },
            "realtime": {
                "title": "Real-Time Engine",
                "description": "A highly concurrent real-time messaging engine built with Go and WebSockets.",
                "items": [
                    "**Go (Golang):** Core of the real-time system, optimized for massive concurrency and low latency.",
                    "**Gorilla WebSocket:** Full-duplex communication between client and server for instant messaging.",
                    "**Room-based architecture:** Hub and room system for chat segmentation and horizontal scalability.",
                    "**Concurrency model:** Efficient handling of thousands of simultaneous connections using goroutines and channels.",
                    "**Security layer:** Token validation via PHP backend before establishing WebSocket connections.",
                    "**MySQL integration:** Message persistence with permission control and direct query validation."
                ]
            },
            "tools": {
                "title": "Tools & Ecosystem",
                "description": "Specialized libraries that perfect every detail of the social network.",
                "items": [
                    "**Axios:** Efficient HTTP request management with security interceptors.",
                    "**React Easy Crop:** Intuitive tool for the perfect fit of avatars and banners.",
                    "**React Testing Library:** UI quality assurance by simulating real user interactions."
                ]
            }
        }
    },
