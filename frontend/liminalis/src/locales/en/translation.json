    "aboutPage": {
        "title": "About Liminalis",
        "mission_title": "Our Mission",
        "mission_text": "Liminalis was born as a space to connect ideas in the digital age, prioritizing privacy, customization, and real community.",
        "features_title": "Why Liminalis?",
        "features": {
            "privacy": {
                "title": "Privacy First",
                "desc": "Your data is yours. We encrypt your information and give you total control."
            },
            "custom": {
                "title": "Customization",
                "desc": "From visual themes to font size. Your space, your rules."
            },
            "open": {
                "title": "Open Source",
                "desc": "We believe in transparency. You can review our code on GitHub."
